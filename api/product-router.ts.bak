import { z } from "zod";
import { eq, desc, asc, like, and, sql } from "drizzle-orm";
import { createRouter, publicQuery, adminQuery } from "./middleware";
import { getDb } from "./queries/connection";
import { products, categories, licenseKeys } from "@db/schema";

export const productRouter = createRouter({
  list: publicQuery
    .input(
      z.object({
        categoryId: z.number().int().optional(),
        search: z.string().optional(),
        sort: z.enum(["newest", "price_asc", "price_desc", "popular"]).optional().default("newest"),
        status: z.enum(["active", "inactive", "draft", "all"]).optional().default("active"),
        page: z.number().int().min(1).optional().default(1),
        limit: z.number().int().min(1).max(100).optional().default(20),
      }).optional()
    )
    .query(async ({ input }) => {
      const db = getDb();
      const { categoryId, search, sort, status, page, limit } = input ?? {};
      
      const conditions = [];
      
      if (status && status !== "all") {
        conditions.push(eq(products.status, status));
      } else {
        conditions.push(eq(products.status, "active"));
      }
      
      if (categoryId) {
        conditions.push(eq(products.categoryId, categoryId));
      }
      
      if (search) {
        conditions.push(like(products.name, `%${search}%`));
      }
      
      const where = conditions.length > 0 ? and(...conditions) : undefined;
      
      let orderBy;
      switch (sort) {
        case "price_asc":
          orderBy = asc(products.price);
          break;
        case "price_desc":
          orderBy = desc(products.price);
          break;
        case "popular":
          orderBy = desc(products.soldCount);
          break;
        default:
          orderBy = desc(products.createdAt);
      }
      
      const offset = ((page ?? 1) - 1) * (limit ?? 20);
      
      const items = await db.query.products.findMany({
        where,
        orderBy,
        limit,
        offset,
        with: {
          category: true,
        },
      });
      
      const countResult = await db.select({ count: sql<number>`count(*)` })
        .from(products)
        .where(where);
      
      const total = Number(countResult[0]?.count ?? 0);
      
      return {
        items,
        total,
        page: page ?? 1,
        totalPages: Math.ceil(total / (limit ?? 20)),
      };
    }),

  getById: publicQuery
    .input(z.object({ id: z.number().int().positive() }))
    .query(async ({ input }) => {
      const db = getDb();
      const product = await db.query.products.findFirst({
        where: eq(products.id, input.id),
        with: {
          category: true,
        },
      });
      return product ?? null;
    }),

  getBySlug: publicQuery
    .input(z.object({ slug: z.string() }))
    .query(async ({ input }) => {
      const db = getDb();
      const product = await db.query.products.findFirst({
        where: eq(products.slug, input.slug),
        with: {
          category: true,
        },
      });
      return product ?? null;
    }),

  create: adminQuery
    .input(
      z.object({
        name: z.string().min(1).max(255),
        slug: z.string().min(1).max(255),
        description: z.string().optional(),
        shortDescription: z.string().max(500).optional(),
        price: z.string().regex(/^\d+(\.\d{1,2})?$/),
        compareAtPrice: z.string().regex(/^\d+(\.\d{1,2})?$/).optional(),
        categoryId: z.number().int().positive(),
        type: z.enum(["file", "license", "service", "subscription"]).default("file"),
        image: z.string().optional(),
        fileUrl: z.string().optional(),
        fileSize: z.string().optional(),
        stock: z.number().int().min(-1).default(-1),
        status: z.enum(["active", "inactive", "draft"]).default("draft"),
        visibility: z.enum(["public", "private"]).default("public"),
        tags: z.array(z.string()).optional(),
        licenseKeys: z.array(z.string()).optional(),
      })
    )
    .mutation(async ({ ctx, input }) => {
      const db = getDb();
      
      const { licenseKeys: keys, ...productData } = input;
      
      const result = await db.insert(products).values({
        ...productData,
        sellerId: ctx.user.id,
        tags: productData.tags ?? [],
      });
      
      const productId = Number(result[0].insertId);
      
      if (keys && keys.length > 0) {
        await db.insert(licenseKeys).values(
          keys.map((key) => ({
            productId,
            key,
            status: "available" as const,
          }))
        );
      }
      
      await db.update(categories)
        .set({ productCount: sql`product_count + 1` })
        .where(eq(categories.id, productData.categoryId));
      
      return { id: productId, ...productData };
    }),

  update: adminQuery
    .input(
      z.object({
        id: z.number().int().positive(),
        name: z.string().min(1).max(255).optional(),
        description: z.string().optional(),
        shortDescription: z.string().max(500).optional(),
        price: z.string().regex(/^\d+(\.\d{1,2})?$/).optional(),
        compareAtPrice: z.string().regex(/^\d+(\.\d{1,2})?$/).optional(),
        categoryId: z.number().int().positive().optional(),
        type: z.enum(["file", "license", "service", "subscription"]).optional(),
        image: z.string().optional(),
        fileUrl: z.string().optional(),
        fileSize: z.string().optional(),
        stock: z.number().int().min(-1).optional(),
        status: z.enum(["active", "inactive", "draft"]).optional(),
        visibility: z.enum(["public", "private"]).optional(),
        tags: z.array(z.string()).optional(),
      })
    )
    .mutation(async ({ input }) => {
      const db = getDb();
      const { id, ...data } = input;
      
      await db.update(products)
        .set({ ...data, updatedAt: new Date() })
        .where(eq(products.id, id));
      
      return { success: true };
    }),

  delete: adminQuery
    .input(z.object({ id: z.number().int().positive() }))
    .mutation(async ({ input }) => {
      const db = getDb();
      await db.delete(products).where(eq(products.id, input.id));
      return { success: true };
    }),

  getFeatured: publicQuery.query(async () => {
    const db = getDb();
    const featured = await db.query.products.findMany({
      where: and(eq(products.status, "active"), eq(products.visibility, "public")),
      orderBy: desc(products.soldCount),
      limit: 8,
      with: {
        category: true,
      },
    });
    return featured;
  }),
});
